{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "aptPkgs": [
            "ghostscript",
            "qpdf"
          ]
        },
        "install": {
          "cmds": [
            "npm install"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npm start"
  }
}